```gitignore
# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
.env/
ENV/

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Media and static files
media/
staticfiles/

# Environment variables
.env
.env.*
!.env.example

# VS Code
.vscode/

# PyCharm
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Python test/cache tools
.pytest_cache/
.coverage
htmlcov/

# Migrations cache
*.mo
*.pot

# mypy
.mypy_cache/

# Ruff / lint
.ruff_cache/

# Distribution / packaging
build/
dist/
*.egg-info/


# Jupyter
.ipynb_checkpoints/

# PostgreSQL dumps
*.sql

# Logs
logs/
*.log
```
